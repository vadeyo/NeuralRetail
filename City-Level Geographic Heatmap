DATA_PATH = Path("data/raw/retail_transactions.csv")


@st.cache_data(ttl=600, show_spinner="Loading transaction data …")
def load_city_data(path: Path) -> pd.DataFrame:
    df = pd.read_csv(path, parse_dates=["Date"])

    # Aggregate by city
    city_agg = df.groupby("City").agg(
        total_revenue    = ("Total_Cost",       "sum"),
        transaction_count= ("Transaction_ID",   "count"),
        avg_basket       = ("Total_Cost",        "mean"),
        avg_items        = ("Total_Items",       "mean"),
        promo_rate       = ("Promotion",         lambda x: (x != "None").mean()),
        discount_rate    = ("Discount_Applied",  "mean"),
        unique_customers = ("Customer_Name",     "nunique"),
    ).reset_index()

    # Compute churn rate: customers with recency > 90 days
    snapshot = df["Date"].max()
    last_seen = df.groupby("Customer_Name").agg(
        last_date = ("Date", "max"),
        city      = ("City", "last"),
    ).reset_index()
    last_seen["churned"] = (snapshot - last_seen["last_date"]).dt.days > 90
    churn_by_city = (
        last_seen.groupby("city")
        .agg(churn_rate=("churned", "mean"))
        .reset_index()
        .rename(columns={"city": "City"})
    )
    city_agg = city_agg.merge(churn_by_city, on="City", how="left")

    # Attach coordinates
    city_agg["lat"] = city_agg["City"].map(lambda c: CITY_COORDS.get(c, (None, None))[0])
    city_agg["lon"] = city_agg["City"].map(lambda c: CITY_COORDS.get(c, (None, None))[1])
    city_agg = city_agg.dropna(subset=["lat", "lon"])

    return city_agg


def render():
    st.set_page_config(page_title="Geography · NeuralRetail", layout="wide", page_icon="🗺️")

    st.title("🗺️ City-Level Geographic Intelligence")
    st.caption(
        "Revenue, churn, basket size and promotion uptake mapped across cities. "
        "Use the controls below to switch metrics."
    )

    if not DATA_PATH.exists():
        st.error(
            f"Dataset not found at `{DATA_PATH}`. "
            "Download from Kaggle and place at `data/raw/retail_transactions.csv`."
        )
        st.stop()

    df = load_city_data(DATA_PATH)

    # ── Controls ─────────────────────────────────────────────────────────────
    col_ctrl1, col_ctrl2, col_ctrl3 = st.columns([2, 2, 2])
    with col_ctrl1:
        metric = st.selectbox(
            "Metric",
            options=[
                "total_revenue",
                "transaction_count",
                "avg_basket",
                "churn_rate",
                "promo_rate",
                "discount_rate",
                "unique_customers",
            ],
            format_func=lambda x: {
                "total_revenue":     "Total Revenue ($)",
                "transaction_count": "Transaction Count",
                "avg_basket":        "Avg Basket Value ($)",
                "churn_rate":        "Churn Rate (%)",
                "promo_rate":        "Promotion Uptake (%)",
                "discount_rate":     "Discount Rate (%)",
                "unique_customers":  "Unique Customers",
            }[x],
        )
    with col_ctrl2:
        map_style = st.radio("Map type", ["Bubble map", "Choropleth (US states)"], horizontal=True)
    with col_ctrl3:
        top_n = st.slider("Show top N cities", min_value=5, max_value=len(df), value=min(20, len(df)))

    df_top = df.nlargest(top_n, metric)

    # Format label
    label_fmt = {
        "total_revenue":     lambda v: f"${v:,.0f}",
        "transaction_count": lambda v: f"{v:,}",
        "avg_basket":        lambda v: f"${v:.2f}",
        "churn_rate":        lambda v: f"{v*100:.1f}%",
        "promo_rate":        lambda v: f"{v*100:.1f}%",
        "discount_rate":     lambda v: f"{v*100:.1f}%",
        "unique_customers":  lambda v: f"{v:,}",
    }
    df_top["label"] = df_top[metric].apply(label_fmt[metric])

    # ── Map ───────────────────────────────────────────────────────────────────
    color_scales = {
        "total_revenue":     "Viridis",
        "transaction_count": "Blues",
        "avg_basket":        "Teal",
        "churn_rate":        "Reds",
        "promo_rate":        "Purples",
        "discount_rate":     "Oranges",
        "unique_customers":  "Greens",
    }

    if map_style == "Bubble map":
        fig = px.scatter_mapbox(
            df_top,
            lat           = "lat",
            lon           = "lon",
            size          = metric,
            color         = metric,
            hover_name    = "City",
            hover_data    = {
