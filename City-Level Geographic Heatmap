                "transaction_count": True,
                "avg_basket":        ":.2f",
                "churn_rate":        ":.2%",
                "promo_rate":        ":.2%",
                "unique_customers":  True,
                "lat":               False,
                "lon":               False,
            },
            color_continuous_scale = color_scales[metric],
            size_max      = 50,
            zoom          = 3,
            mapbox_style  = "carto-positron",
            title         = f"{metric.replace('_', ' ').title()} by City",
        )
        fig.update_layout(
            height              = 520,
            margin              = dict(l=0, r=0, t=40, b=0),
            coloraxis_colorbar  = dict(title=metric.replace("_", " ").title()),
