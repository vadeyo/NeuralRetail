"""
NeuralRetail — Kafka Transaction Producer
==========================================
Reads retail_transactions.csv row-by-row and publishes each transaction
to a Kafka topic, simulating a real-time point-of-sale stream.

Topic schema (JSON):
    {
        "transaction_id":   "4821937650",
        "date":             "2023-07-14T14:32:00",
        "customer_name":    "Sarah Johnson",
        "product":          ["Milk", "Bread", "Eggs"],
        "total_items":      3,
        "total_cost":       12.45,
        "payment_method":   "Credit Card",
        "city":             "Chicago",
        "store_type":       "Supermarket",
        "discount_applied": true,
        "customer_category":"Adult",
        "season":           "Summer",
        "promotion":        "BOGO",
        "ingested_at":      "2026-06-01T10:00:00.123456"   ← wall-clock timestamp
    }

Usage
-----
    # Default: replay CSV at 10 events/sec into topic 'retail-transactions'
    python src/kafka/producer.py

    # Faster replay (100 events/sec) into a custom topic
    python src/kafka/producer.py --rate 100 --topic my-topic

    # One-shot: send all rows immediately (no delay)
    python src/kafka/producer.py --rate 0

    # Point to a remote broker
    python src/kafka/producer.py --broker kafka-host:9092

Requirements
------------
    pip install kafka-python pandas tqdm
"""

import argparse
import ast
import json
import logging
import time
from datetime import datetime, timezone
from pathlib import Path

import pandas as pd
from kafka import KafkaProducer
from kafka.errors import NoBrokersAvailable
from tqdm import tqdm

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")
log = logging.getLogger(__name__)

DATA_PATH     = Path("data/raw/retail_transactions.csv")
DEFAULT_TOPIC  = "retail-transactions"
DEFAULT_BROKER = "localhost:9092"
DEFAULT_RATE   = 10        # rows per second; 0 = no throttle


def parse_product_field(raw) -> list:
    """
    Product column may be stored as a Python-list string "['Milk', 'Bread']"
    or a plain comma-separated string "Milk, Bread".
    Normalise to a clean Python list.
    """
    if isinstance(raw, list):
        return raw
    raw = str(raw).strip()
    if raw.startswith("["):
        try:
            return ast.literal_eval(raw)
        except (ValueError, SyntaxError):
            pass
    return [item.strip() for item in raw.split(",") if item.strip()]


def row_to_event(row: pd.Series) -> dict:
    """Convert a DataFrame row to the canonical Kafka event dict."""
    date_val = row.get("Date", "")
    if hasattr(date_val, "isoformat"):
        date_str = date_val.isoformat()
    else:
        date_str = str(date_val)

    return {
        "transaction_id":   str(row.get("Transaction_ID", "")),
        "date":             date_str,
        "customer_name":    str(row.get("Customer_Name", "")),
        "product":          parse_product_field(row.get("Product", [])),
        "total_items":      int(row.get("Total_Items", 0)),
        "total_cost":       float(row.get("Total_Cost", 0.0)),
        "payment_method":   str(row.get("Payment_Method", "")),
        "city":             str(row.get("City", "")),
        "store_type":       str(row.get("Store_Type", "")),
        "discount_applied": bool(row.get("Discount_Applied", False)),
        "customer_category":str(row.get("Customer_Category", "")),
        "season":           str(row.get("Season", "")),
        "promotion":        str(row.get("Promotion", "None")),
        "ingested_at":      datetime.now(timezone.utc).isoformat(),
    }


def on_send_success(record_metadata):
    log.debug(
        "✓ Delivered → topic=%s  partition=%d  offset=%d",
        record_metadata.topic, record_metadata.partition, record_metadata.offset,
    )


def on_send_error(exc):
    log.error("✗ Delivery failed: %s", exc)


def build_producer(broker: str) -> KafkaProducer:
    return KafkaProducer(
        bootstrap_servers  = [broker],
        value_serializer   = lambda v: json.dumps(v).encode("utf-8"),
        key_serializer     = lambda k: k.encode("utf-8"),
        acks               = "all",       # wait for all in-sync replicas
        retries            = 5,
        compression_type   = "gzip",
        linger_ms          = 5,           # micro-batch for throughput
        batch_size         = 16_384,
    )


def produce(broker: str, topic: str, data_path: Path, rate: float):
    log.info("Connecting to broker %s …", broker)
    try:
        producer = build_producer(broker)
    except NoBrokersAvailable:
        log.error(
            "No Kafka broker reachable at %s.\n"
            "Start a local broker with:  docker-compose up kafka\n"
            "Or run:  docker run -p 9092:9092 apache/kafka:3.7.0",
            broker,
        )
        raise

    log.info("Loading dataset from %s …", data_path)
    df = pd.read_csv(data_path, parse_dates=["Date"])
    total = len(df)
    log.info("Publishing %d rows to topic '%s' at %s events/sec …",
             total, topic, rate if rate > 0 else "max")

    delay = 1.0 / rate if rate > 0 else 0.0
    sent  = 0
    errs  = 0

    with tqdm(total=total, unit="tx", desc="Streaming") as pbar:
        for _, row in df.iterrows():
            event = row_to_event(row)
            key   = event["transaction_id"]
            (
                producer
                .send(topic, value=event, key=key)
                .add_callback(on_send_success)
                .add_errback(on_send_error)
            )
            sent += 1
            pbar.update(1)

            if delay:
                time.sleep(delay)

            # Flush every 1000 messages to prevent buffer overflow
            if sent % 1_000 == 0:
                producer.flush()

    producer.flush()
    producer.close()
    log.info("Done. Sent=%d  Errors=%d", sent, errs)


def main():
    parser = argparse.ArgumentParser(description="NeuralRetail Kafka producer")
    parser.add_argument("--broker", default=DEFAULT_BROKER,  help="Kafka broker address")
    parser.add_argument("--topic",  default=DEFAULT_TOPIC,   help="Target Kafka topic")
    parser.add_argument("--data",   default=str(DATA_PATH),  help="Path to retail_transactions.csv")
    parser.add_argument("--rate",   type=float, default=DEFAULT_RATE,
                        help="Events per second (0 = unlimited)")
    args = parser.parse_args()

    produce(args.broker, args.topic, Path(args.data), args.rate)


if __name__ == "__main__":
    main()
